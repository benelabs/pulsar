{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "dist",
    "rootDir": "./",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": ["src/**/*", "tests/**/*", "vitest.config.ts"],
  "include": [
    "src/**/*",
    "tests/**/*",
    "tools/account_merge.ts",
    "tools/account_merge.test.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
