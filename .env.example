# ─── Network ────────────────────────────────────────────────────────────────
# Options: mainnet | testnet | futurenet | custom
# Default: testnet
STELLAR_NETWORK=testnet

# Override the Horizon REST endpoint (optional)
# Example: https://horizon-testnet.stellar.org
HORIZON_URL=

# Override the Soroban RPC endpoint (optional)
# Example: https://soroban-testnet.stellar.org
SOROBAN_RPC_URL=

# Comma-separated list of Soroban RPC endpoints for latency-based routing.
# If provided, pulsar will automatically route requests to the fastest healthy endpoint.
# Example for redundancy: SOROBAN_RPC_URLS=https://rpc1.example.com,https://rpc2.example.com
SOROBAN_RPC_URLS=

# ─── Signing (optional) ──────────────────────────────────────────────────────
# Required only for `submit_transaction` tool with `sign: true`.
# WARNING: Never commit a funded secret key to version control.
# Use a throwaway Testnet key funded via https://friendbot.stellar.org
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Soroban CLI ────────────────────────────────────────────────────────────
# Path to the `stellar` binary. Pulsar will auto-detect from PATH if unset.
# Minimum required version: 21.0.0
STELLAR_CLI_PATH=stellar

# ─── Server ─────────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug
# Default: info
LOG_LEVEL=info

# Tool execution audit log path.
# Default: audit.log
AUDIT_LOG_PATH=audit.log
# ─── RPC Routing ─────────────────────────────────────────────────────────────
# RPC health check interval in milliseconds (default: 30000)
# RPC_HEALTH_CHECK_INTERVAL_MS=30000

# Maximum acceptable latency for an RPC endpoint (ms) before marking it unhealthy (default: 2000)
# RPC_LATENCY_THRESHOLD_MS=2000
